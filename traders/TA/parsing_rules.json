  "regex_patterns": {
    "symbol": [
      "#\\s*([A-Z0-9]{2,20}USDT(?:\\.P)?)\\b",
      "\\b([A-Z0-9]{2,20}USDT(?:\\.P)?)\\b"
    ],
    "result_r": [
      "\\b[A-Z]{2,20}(?:USDT|USDC|USD|BTC|ETH)?\\s*[-:=]\\s*[+-]?\\d+(?:[.,]\\d+)?\\s*R\\b"
    ],
    "tp_index": [
      "\\btp(\\d+)\\b"
    ],
    "percent": [
      "\\b\\d+(?:[.,]\\d+)?%\\b"
    ],
    "entry": [
      "\\bвход(?:\\s*\\([abаб]\\))?(?:\\s+с\\s+текущих|\\s+лимиткой)?\\s*[:=@-]?\\s*([0-9][0-9.,]*(?:\\s*-\\s*[0-9][0-9.,]*)?)"
    ],
    "market_entry": [
      "(?:\\(\\s*вход\\s+с\\s+текущих\\s*\\)|\\bвход\\s+с\\s+текущих\\b)"
    ],
    "averaging": [
      "(?:усреднение|втор(?:ой|ая)\\s+вход)\\s*[:=@-]?\\s*([0-9][0-9.,]*(?:\\s*-\\s*[0-9][0-9.,]*)?)"
    ],
    "stop": [
      "(?:\\bsl\\b|\\bстоп\\b)\\s*[:=@-]?\\s*([0-9][0-9.,]*)"
    ],
    "tp": [
      "\\btp\\d*\\s*[:=@-]?\\s*([0-9][0-9.,]*)"
    ],
    "risk": [
      "(?:риск\\s+на\\s+сделку|risk)\\s*[:=@-]?\\s*([0-9]+(?:[.,][0-9]+)?\\s*%)"
    ],
    "entry_cancel": [
      "(отмена\\s+входа[^\\n\\r]*)"
    ],
    "stop_out": [
      "(?:к\\s+сожалению\\s+стоп|словили\\s*-\\s*\\d+(?:[.,]\\d+)?%|стоп\\s*[-:]\\s*-\\d+(?:[.,]\\d+)?%)"
    ],
    "limit_avg_update": [
      "лимитка\\W+моя\\s+средняя"
    ],
    "linked_update_hint": [
      "(?:лимитка|средняя|тейк|стоп\\s+в\\s+бу|breakeven|убра(?:ть|ем)\\s+лимитку)"
    ]
  },
  "ignore_if_contains": [
