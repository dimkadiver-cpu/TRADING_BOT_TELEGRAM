{
  "profile_options": {
    "language": "ru",
    "parser_mode": "hybrid_auto",
    "allows_multi_intent": true,
    "prefer_reply_linkage": true,
    "prefer_telegram_linkage": true
  },
  "message_type_markers": {
    "NEW_SIGNAL": [
      "LONG",
      "SHORT",
      "Вход с текущих",
      "Вход лимиткой",
      "Stop",
      "Тейк-профит",
      "Тейки",
      "$"
    ],
    "UPDATE": [
      "В бу перевел",
      "Перевод в бу",
      "Перевод в безубыток",
      "Не актуально"
    ],
    "INFO_ONLY": [],
    "RESULT_REPORT": [
      "Тп1",
      "Тп2",
      "Тп3",
      "TP1",
      "TP2",
      "TP3",
      "Стоп -",
      "остаток ушел в бу",
      "позиция ушла в бу"
    ]
  },
  "intent_keywords": {
    "U_MOVE_STOP_TO_BE": [
      "В бу перевел",
      "Перевод в бу",
      "Перевод в безубыток"
    ],
    "U_INVALIDATE_SETUP": [
      "Не актуально"
    ],
    "U_TP_HIT": [
      "Тп1",
      "Тп2",
      "Тп3",
      "TP1",
      "TP2",
      "TP3"
    ],
    "U_STOP_HIT": [
      "Стоп -",
      "стоп -"
    ],
    "I_REMAINDER_CLOSED_AT_BE": [
      "остаток ушел в бу",
      "позиция ушла в бу",
      "ушла в бу"
    ]
  },
  "regex_patterns": {
    "symbol": [
      "\\$([A-Z0-9]{2,20}USDT(?:\\.P)?)"
    ],
    "tp_index": [
      "\\b[ТT][пP]\\s*([1-5])\\b",
      "\\bTP\\s*([1-5])\\b"
    ],
    "percent": [
      "([+-]?\\d+(?:[.,]\\d+)?)"
    ],
    "telegram_link": [
      "https?://t\\.me/[^\\s]+"
    ]
  },
  "ignore_if_contains": [
    "#admin"
  ],
  "phrase_templates": {
    "market_entry": [
      "Вход с текущих"
    ],
    "limit_entry": [
      "Вход лимиткой"
    ],
    "be_update": [
      "В бу перевел"
    ],
    "be_event": [
      "остаток ушел в бу",
      "позиция ушла в бу"
    ]
  }
}
