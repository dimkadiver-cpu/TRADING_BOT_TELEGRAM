    "marker_context_exclusions": [
      {
        "name": "all_short_in_ps_informational_context",
        "strength": "strong",
        "marker_name": "ALL_SHORT",
        "markers": {"source": "semantic"},
        "scope": "whole_message",
        "if_contains_any": ["p.s.", "у вас прибыль по шортам"],
