      },
      {
        "name": "exit_be_weak_context",
        "intent": "EXIT_BE",
        "markers": {"source": "intent_weak"},
        "scope": "same_sentence",
        "if_regex_any": ["\\b(\\w+бу\\w*|\\w*бу\\w+)\\b"],
        "if_contains_any": ["обидный бу.","не переносим в бу","фактически в бу","в бу закрылись", "закрыть сделку в бу",
         "закрыть позицию в бу","закрываем в бу"],
        "reason": "false_positive_weak_markers_in_exit_be_context"
      },


      {
        "name": "tp_after_n_tp_historical_context",
        "intent": "TP_HIT",
        "markers": {"source": "intent_weak"},
        "scope": "same_sentence",
        "if_regex_any": [
          "после\\s+(?:\\d+|первого|второго|третьего|четвертого|пятого)\\s+тейка",
          "(?:было|были|был|была)\\s+\\d+\\s+тейк(?:а|ов)?",
          "дошл(?:и|о)?\\s+до\\s+\\d+(?:-х)?\\s+тейк(?:а|ов)?",
          "дожидаться\\s+\\d+\\s+тейк(?:а|ов)?",
          "(?:у|до|с|на)\\s+(?:\\d+|первого|второго|третьего|четвертого|пятого)\\s+тейк(?:а|ов)",
          "Не\\s+(?:дошло|дошли)\\s+до\\s+\\d+\\s+тейк(?:а|ов)?"
        ],
        "if_contains_any": ["стоял другой тейк","закрываю у тейка","1 тейк должны","с тейком", "нормальными тейками","и тейки",
        "закрыть на 1 тейке","порадуют тейками","фиксация на тейках","отбой по тейку","ждать тейков","и тейков"],
        "unless_contains_any": [
          "тейк взят",
          "тейк взяли",
          "взяли тейк",
          "второй тейк взят",
          "третий тейк взят"
        ],
        "reason": "historical_context"
      },
      {
        "name": "sl_hit_ambiguous_general_context",
        "intent": "SL_HIT",
        "markers": {"source": "intent_weak"},
        "scope": "same_sentence",
        "if_contains_any": [
          "стопы переводить","стопы по","риск получить стоп","про стопы","стоп не двигаем","вышли стопы",
          "стоп - это защита","стоп пока не переносим","стоп не переносим","стоп нужно ","стоп поставим",
          "возьмет стоп","стоп возьмет","стоп поставить","стоп обязательно","переводе стопа","стоп уже в бу",
