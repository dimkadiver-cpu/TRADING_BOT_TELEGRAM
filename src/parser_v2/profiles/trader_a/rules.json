{
  "marker_resolution": {
    "suppress_weak_inside_strong_same_intent": true,
    "cross_intent_suppression": [
      {
        "if_strong": "MOVE_STOP_TO_BE",
        "suppress_weak": ["EXIT_BE", "INFO_ONLY"],
        "reason": "command_marker_dominates_be_status_marker"
      },
      {
        "if_strong": "SL_HIT",
        "suppress_weak": ["MOVE_STOP", "MOVE_STOP_TO_BE"],
        "reason": "sl_hit_is_report_not_command"
      },
      {
        "if_strong": "CLOSE_PARTIAL",
        "suppress_weak": ["CLOSE_FULL"],
        "reason": "partial_close_is_more_specific"
      },
      {
        "if_strong": "EXIT_BE",
        "suppress_weak": ["TP_HIT"],
        "reason": "exit_be_after_tp_hit"
      },
       {
        "if_strong": "ENTRY_FILLED",
        "suppress_weak": ["SL_HIT"],
        "reason": "sl_is_protection_after_entry_filled"
      },
       {
        "if_strong": "CLOSE_FULL",
        "suppress_weak": ["SL_HIT"],
        "reason": "sl_is_rummored_to_be_cancelled_by_full_close"
      },
