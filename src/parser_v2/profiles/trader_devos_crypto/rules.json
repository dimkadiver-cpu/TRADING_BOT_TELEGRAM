{
  "marker_resolution": {
    "suppress_weak_inside_strong_same_intent": true,
    "weak_context_exclusions": [
      {
        "name": "cancel_pending_in_signal_context",
        "intent": "CANCEL_PENDING",
        "markers": { "source": "intent_weak" },
        "scope": "whole_message",
        "if_regex_any": [
          "(?i)direction:\\s*(?:long|short)"
