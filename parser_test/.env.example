# parser_test environment example
# Copy to parser_test/.env and fill required values.

# Required Telegram credentials
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Required target for import_history.py if --chat-id is not provided
PARSER_TEST_CHAT_ID=

# Optional parser_test session name
PARSER_TEST_TELEGRAM_SESSION=parser_test

# Optional paths (relative to project root or absolute)
PARSER_TEST_DB_PATH=parser_test/db/parser_test.sqlite3
PARSER_TEST_LOG_PATH=parser_test/logs/import_history.log

# Optional parser mode for replay_parser.py
PARSER_MODE=regex_only
