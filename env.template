# TeleSignalBot environment template
# Copy this file to .env and fill the empty values.
# Do not commit .env or real credentials.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

BOT_ENV=demo
LOG_LEVEL=INFO
LOG_PATH=logs/bot.log

# Runtime v2 database paths.
PARSER_DB_PATH=db/parser.sqlite3
OPS_DB_PATH=db/ops.sqlite3

# Legacy/default database path used by older modules and tools.
DB_PATH=db/tele_signal_bot.sqlite3

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Required by main.py.
TELEGRAM_API_ID=33118095
TELEGRAM_API_HASH=5d1145a020a67c

# Optional. Defaults to "tele_signal_bot" when unset.
TELEGRAM_SESSION=tele_signal_bot

# Optional fallback if config/channels.yaml is not enough.
# Comma-separated chat IDs, for example: -1001234567890,-1009876543210
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional bot/admin settings used by helper tooling or legacy flows.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_SIGNAL_CHANNEL=
TELEGRAM_SOURCE_MAP_PATH=config/telegram_source_map.json

# ---------------------------------------------------------------------------
# Bybit execution gateway - current runtime_v2 config/execution.yaml
# ---------------------------------------------------------------------------

# Required for adapters.bybit_demo in config/execution.yaml.
BYBIT_API_KEY_BYBIT_DEMO=
BYBIT_API_SECRET_BYBIT_DEMO=

# Safety gate for true live mode only.
# Leave empty for demo/paper mode.
# Set exactly to YES_I_UNDERSTAND only when config/execution.yaml has mode: live
# and live_safety.allow_live_trading: true.
TSB_ALLOW_LIVE_TRADING=

# ---------------------------------------------------------------------------
# Bybit gated integration tests
# ---------------------------------------------------------------------------

# Used only by tests marked bybit_testnet.
# These are separate from Bybit Demo Trading credentials.
BYBIT_TESTNET_API_KEY=
BYBIT_API_SECRET_BYBIT_TESTNET=

# ---------------------------------------------------------------------------
# Legacy / optional Bybit settings
# ---------------------------------------------------------------------------

# Older modules or local scripts may still reference these names.
# Prefer BYBIT_API_KEY_BYBIT_DEMO / BYBIT_API_SECRET_BYBIT_DEMO for runtime_v2.
BYBIT_API_KEY=9vaWpi7sm8ktvE28i4
BYBIT_API_SECRET=jTQEGXxxO61ADNKAV67SSaXjuRHFdhezMUgW
BYBIT_TESTNET=
BYBIT_REST_URL=
BYBIT_WS_PRIVATE_URL=
BYBIT_WS_PUBLIC_URL=

# ---------------------------------------------------------------------------
# Legacy execution/UI mirror helpers
# ---------------------------------------------------------------------------

TELESIGNALBOT_DB_PATH=
TELESIGNALBOT_FREQTRADE_TRADES_DB_PATH=

# ---------------------------------------------------------------------------
# Recovery / operations tuning
# ---------------------------------------------------------------------------

RECOVERY_INTERVAL_SECONDS=60
